# =============================================================================
# VclRotatedEdit - Delphi / VCL .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Delphi compiled units and package outputs
# -----------------------------------------------------------------------------
*.dcu
*.dcuil
*.bpl
*.dcp
*.dcpil
*.bpi
*.obj
*.hpp
*.lib
*.a
*.o

# -----------------------------------------------------------------------------
# Executables and runtime binaries
# -----------------------------------------------------------------------------
*.exe
*.dll
*.ocx

# -----------------------------------------------------------------------------
# Debug, map, linker and compiler generated files
# -----------------------------------------------------------------------------
*.tds
*.map
*.rsm
*.drc
*.ilc
*.ild
*.ilf
*.ils
*.pdb
*.jdbg
*.dbg

# -----------------------------------------------------------------------------
# Delphi generated resource files
# -----------------------------------------------------------------------------
*.res

# If a resource file must be versioned because it contains non-generated assets,
# add an explicit exception, for example:
# !Demo/VclRotatedEditDemo.res

# -----------------------------------------------------------------------------
# Delphi project local / user-specific files
# -----------------------------------------------------------------------------
*.local
*.dproj.local
*.groupproj.local
*.identcache
*.dsk
*.dsv
*.stat
*.zip

# -----------------------------------------------------------------------------
# Delphi backup, history and recovery files
# -----------------------------------------------------------------------------
__history/
__recovery/
*.~*
*.bak
*.tmp
*.old
*.orig
*.rej

# -----------------------------------------------------------------------------
# Build output folders
# -----------------------------------------------------------------------------
Win32/
Win64/
Debug/
Release/
Lib/
Dev/

# Same output folders when generated under subdirectories such as Demo/ or Packages/.
**/Win32/
**/Win64/
**/Debug/
**/Release/
**/Lib/
**/Dev/

# -----------------------------------------------------------------------------
# MSBuild and build logs
# -----------------------------------------------------------------------------
*.log
*.binlog
*.build

# -----------------------------------------------------------------------------
# IDE / editor files
# -----------------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# -----------------------------------------------------------------------------
# Windows / Explorer files
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Temporary and cache files
# -----------------------------------------------------------------------------
*.cache
*.temp
*.swp
*.swo

# -----------------------------------------------------------------------------
# Generated documentation
# -----------------------------------------------------------------------------
# Public PasDoc HTML output is intentionally versioned in docs/api/.
# The complete maintainer reference is generated locally and not committed.
docs/api-complete/
